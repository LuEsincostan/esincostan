---

<BaseLayout title="Ludwig Ehlert | Timeline" description="Professional and personal timeline of Ludwig Ehlert.">
  <main class="split-page">
    <header class="site-header">
      <div class="name-box">
        <h1>Ludwig Ehlert</h1>
        <p class="contact-line">
          <a href="mailto:hello@esincostan.com">hello@esincostan.com</a>
          <a href="https://github.com/" target="_blank" rel="noreferrer">GitHub</a>
          <a href="https://www.linkedin.com/in/ludwigehlert/" target="_blank" rel="noreferrer">LinkedIn</a>
        </p>
      </div>
      <button id="info-toggle" class="info-icon-btn" type="button" aria-expanded="false" aria-controls="name-info" aria-label="About this site">i</button>
      <div id="name-info" class="name-info" hidden>
        Placeholder section for the future explanation of the name <strong>esincostan</strong>.
      </div>
    </header>

    <section id="timeline-shell" class="timeline-shell" data-focus="center" aria-label="Professional and personal timeline">
      <div class="timeline-controls">
        <button class="nav-button" type="button" data-nav="left" aria-label="Focus professional side">←</button>
        <p class="controls-label"><span class="label-pro">Professional</span><span class="label-sep">·</span><span class="label-per">Personal</span></p>
        <button class="nav-button" type="button" data-nav="right" aria-label="Focus personal side">→</button>
      </div>

      <div
        id="timeline-interactive"
        class="timeline-interactive"
        tabindex="0"
        role="region"
        aria-label="Swipe, drag, click, or use arrow keys to change focus"
      >
        <ol class="timeline-list">
          {
            events.map((event) => (
              <li class={`timeline-item side-${event.side}${event.sub ? " is-sub" : ""}`}>
                <article class="event-card" data-side={event.side}>
                  <p class="event-summary">{event.summary}</p>
                  {event.dateRange && (
                    <p class="event-date-range">{event.dateRange}</p>
                  )}
                  <p class="event-details" data-side-detail={event.side} aria-expanded="false">
                    {event.details}
                  </p>
                </article>
                <div class="axis-node" aria-hidden="true">
                  <span class="node-dot"></span>
                  <span class="node-date">{event.dateLabel}</span>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>
  </main>

  <script>
    (() => {
      const shell = document.getElementById("timeline-shell");
      const interactive = document.getElementById("timeline-interactive");
      const infoToggle = document.getElementById("info-toggle");
      const infoPanel = document.getElementById("name-info");
      const navButtons = Array.from(document.querySelectorAll("[data-nav]"));
      const details = Array.from(document.querySelectorAll("[data-side-detail]"));

      if (!shell || !interactive || !infoToggle || !infoPanel) return;

      const states = ["left", "center", "right"];
      let index = 1;
      let startX = 0;
      let moved = false;

      const updateDetailsAria = () => {
        const focus = states[index];
        const expandedSide =
          focus === "left" ? "professional" : focus === "right" ? "personal" : "";

        details.forEach((el) => {
          const isExpanded = expandedSide !== "" && el.dataset.sideDetail === expandedSide;
          el.setAttribute("aria-expanded", String(isExpanded));
        });
      };

      const applyFocus = () => {
        shell.dataset.focus = states[index];
        updateDetailsAria();
      };

      const shiftFocus = (delta) => {
        const next = Math.max(0, Math.min(states.length - 1, index + delta));
        if (next === index) return;
        index = next;
        applyFocus();
      };

      navButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const dir = button.getAttribute("data-nav");
          if (dir === "left") shiftFocus(-1);
          if (dir === "right") shiftFocus(1);
          interactive.focus();
        });
      });

      interactive.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          shiftFocus(-1);
        }
        if (event.key === "ArrowRight") {
          event.preventDefault();
          shiftFocus(1);
        }
      });

      interactive.addEventListener("pointerdown", (event) => {
        startX = event.clientX;
        moved = false;
      });

      interactive.addEventListener("pointermove", (event) => {
        if (Math.abs(event.clientX - startX) > 8) moved = true;
      });

      interactive.addEventListener("pointerup", (event) => {
        const deltaX = event.clientX - startX;
        const threshold = 42;

        if (Math.abs(deltaX) >= threshold) {
          // Swipe left = reveal right side, swipe right = reveal left side.
          if (deltaX < 0) shiftFocus(1);
          if (deltaX > 0) shiftFocus(-1);
          return;
        }

        if (!moved) {
          const rect = interactive.getBoundingClientRect();
          const relativeX = event.clientX - rect.left;
          const ratio = relativeX / rect.width;

          if (ratio < 0.35) {
            index = 0;
            applyFocus();
          } else if (ratio > 0.65) {
            index = 2;
            applyFocus();
          } else {
            index = 1;
            applyFocus();
          }
        }
      });

      infoToggle.addEventListener("click", () => {
        const expanded = infoToggle.getAttribute("aria-expanded") === "true";
        infoToggle.setAttribute("aria-expanded", String(!expanded));
        infoPanel.hidden = expanded;
      });

      applyFocus();
    })();
  </script>
</BaseLayout>
