---
import BaseLayout from "../layouts/BaseLayout.astro";

const year = new Date().getFullYear();
---

<BaseLayout title="Esin Costan | Professional + Personal" description="Professional and personal presentation page for Esin Costan.">
  <main class="pcb-page">
    <header class="pcb-hero">
      <section class="intro intro-pro" aria-label="Professional profile summary">
        <p class="intro-tag">Professional</p>
        <p>Dataiku (Zurich), analytics engineering, technical sales, and AI enablement.</p>
      </section>

      <div class="intro-center">
        <p class="domain">esincostan.com</p>
        <h1>Esin Costan</h1>
        <p class="tagline">Two sides, one timeline.</p>
      </div>

      <section class="intro intro-personal" aria-label="Personal profile summary">
        <p class="intro-tag">Personal</p>
        <p>Curiosity, endurance, and a constant bias toward practical growth.</p>
      </section>
    </header>

    <section class="pcb-board" aria-label="Shared timeline connecting professional and personal life">
      <section class="side side-pro" aria-labelledby="professional-title">
        <h2 id="professional-title">Professional</h2>
        <ul>
          <li>Current company: Dataiku (Zurich, Switzerland)</li>
          <li>Visible profile reach: 1K followers / 500+ connections</li>
          <li>Focus areas: enterprise AI adoption and data tooling</li>
        </ul>
      </section>

      <section class="side side-personal" aria-labelledby="personal-title">
        <h2 id="personal-title">Personal</h2>
        <ul>
          <li>Long-distance sports and resilience</li>
          <li>Learning by making and shipping</li>
          <li>Intentional, low-noise communication</li>
        </ul>
      </section>

      <div class="tree-core" aria-hidden="true">
        <svg class="tree-svg" viewBox="0 0 220 900" role="presentation">
          <g class="tree-traces">
            <path d="M110 890 V620" />
            <path d="M96 890 V650" />
            <path d="M124 890 V650" />

            <path d="M110 620 V220" />
            <path d="M110 560 H76 V510 H48" />
            <path d="M110 560 H144 V510 H172" />
            <path d="M110 530 H84 V470 H60 V430 H34" />
            <path d="M110 530 H136 V470 H160 V430 H186" />
            <path d="M110 500 H90 V435 H66" />
            <path d="M110 500 H130 V435 H154" />
            <path d="M110 470 H94 V390 H78 V340 H58" />
            <path d="M110 470 H126 V390 H142 V340 H162" />
            <path d="M110 440 H86 V356 H64 V312 H44" />
            <path d="M110 440 H134 V356 H156 V312 H176" />
            <path d="M110 408 H96 V336 H80 V292" />
            <path d="M110 408 H124 V336 H140 V292" />
            <path d="M110 372 H100 V300 H86 V252" />
            <path d="M110 372 H120 V300 H134 V252" />
            <path d="M110 340 H96 V270 H72 V224" />
            <path d="M110 340 H124 V270 H148 V224" />
          </g>
          <g class="tree-pads">
            <circle cx="110" cy="620" r="7" />
            <circle cx="48" cy="510" r="6" />
            <circle cx="172" cy="510" r="6" />
            <circle cx="34" cy="430" r="6" />
            <circle cx="186" cy="430" r="6" />
            <circle cx="66" cy="435" r="6" />
            <circle cx="154" cy="435" r="6" />
            <circle cx="58" cy="340" r="6" />
            <circle cx="162" cy="340" r="6" />
            <circle cx="44" cy="312" r="6" />
            <circle cx="176" cy="312" r="6" />
            <circle cx="80" cy="292" r="6" />
            <circle cx="140" cy="292" r="6" />
            <circle cx="86" cy="252" r="6" />
            <circle cx="134" cy="252" r="6" />
            <circle cx="72" cy="224" r="6" />
            <circle cx="148" cy="224" r="6" />
          </g>
        </svg>
      </div>

      <ol class="pcb-timeline">
        <li class="node">
          <article class="event event-pro">
            <p class="event-year">2016</p>
            <p>Earned Tableau Desktop 10 Qualified Associate (issued Nov 2016).</p>
          </article>
          <div class="joint" aria-hidden="true">
            <span class="pad"></span>
            <span class="stamp">2016</span>
          </div>
        </li>

        <li class="node">
          <article class="event event-pro">
            <p class="event-year">2018</p>
            <p>Completed Tableau Server Certified Professional (issued Jan 2018).</p>
          </article>
          <div class="joint" aria-hidden="true">
            <span class="pad"></span>
            <span class="stamp">2018</span>
          </div>
          <article class="event event-personal">
            <p class="event-year">2018</p>
            <p>Committed to endurance training as a long-term discipline and mindset practice.</p>
          </article>
        </li>

        <li class="node">
          <article class="event event-pro">
            <p class="event-year">2024</p>
            <p>Earned Microsoft Certified: Fabric Analytics Engineer Associate (Aug 2024).</p>
          </article>
          <div class="joint" aria-hidden="true">
            <span class="pad"></span>
            <span class="stamp">2024</span>
          </div>
          <article class="event event-personal">
            <p class="event-year">2024</p>
            <p>Built a personal routine around consistency, reflection, and deliberate learning.</p>
          </article>
        </li>

        <li class="node">
          <article class="event event-pro">
            <p class="event-year">2025</p>
            <p>Issued Dataiku Core Designer (Mar 2025) and active in AI workshops in Switzerland.</p>
          </article>
          <div class="joint" aria-hidden="true">
            <span class="pad"></span>
            <span class="stamp">2025</span>
          </div>
        </li>

        <li class="node">
          <article class="event event-pro">
            <p class="event-year">2026</p>
            <p>Shared Dataiku 575 Lab announcement focused on open source AI governance tooling.</p>
          </article>
          <div class="joint" aria-hidden="true">
            <span class="pad"></span>
            <span class="stamp">2026</span>
          </div>
          <article class="event event-personal">
            <p class="event-year">Now</p>
            <p>Combining professional rigor with a human, grounded personal pace.</p>
          </article>
        </li>
      </ol>
    </section>

    <footer class="pcb-footer" id="contact">
      <p>
        <a href="mailto:hello@esincostan.com">hello@esincostan.com</a>
        <span class="separator">|</span>
        <a href="https://github.com/" target="_blank" rel="noreferrer">GitHub</a>
        <span class="separator">|</span>
        <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>
      </p>
      <p>© {year} Esin Costan</p>
    </footer>
  </main>
</BaseLayout>
